---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { CATEGORIES, SITE_TITLE, tagToSlug } from '../../consts';

export async function getStaticPaths() {
  return CATEGORIES.map((cat) => ({
    params: { categoria: cat.slug },
    props: { category: cat },
  }));
}

const { category } = Astro.props;

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((post) =>
    post.data.tags?.some((tag: string) => tagToSlug(tag) === category.slug)
  )
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<html lang="pt-BR">
  <head>
    <BaseHead
      title={`${category.name} | ${SITE_TITLE}`}
      description={`Artigos sobre ${category.name} para tutores de pets.`}
    />
  </head>
  <body>
    <Header />
    <main>
      <h1>{category.name}</h1>
      <p>{posts.length} artigo{posts.length !== 1 ? 's' : ''} encontrado{posts.length !== 1 ? 's' : ''}.</p>
      <ul>
        {posts.map((post) => (
          <li>
            <a href={`/blog/${post.id}/`}>{post.data.title}</a>
            <p>{post.data.description}</p>
          </li>
        ))}
      </ul>
    </main>
    <Footer />
  </body>
</html>