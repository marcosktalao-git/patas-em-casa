---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE, CATEGORIES } from '../consts';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>

      <!-- HERO -->
      <section class="hero">
        <div class="hero-content">
          <h1>Cuide Bem de Quem Te Faz Feliz Todo Dia 🐾</h1>
          <p>Dicas práticas de saúde, alimentação, comportamento e produtos para cães e gatos. Para famílias que amam seus pets.</p>
          <a href="/blog" class="btn-primary">Ver todos os artigos</a>
        </div>
      </section>

      <!-- CATEGORIAS -->
      <section class="categorias">
        <h2>Explore por Categoria</h2>
        <div class="categorias-grid">
          {CATEGORIES.map((cat) => (
            <a href={`/categoria/${cat.slug}/`} class="categoria-card">
              <span class="categoria-nome">{cat.name}</span>
            </a>
          ))}
        </div>
      </section>

      <!-- ARTIGOS RECENTES -->
      <section class="artigos-recentes">
        <h2>Artigos Recentes</h2>
        <div class="artigos-grid">
          {posts.map((post) => (
            <a href={`/blog/${post.id}/`} class="artigo-card">
              {post.data.heroImage && (
                <img src={post.data.heroImage.src} alt={post.data.title} />
              )}
              <div class="artigo-info">
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                <span class="artigo-data"><FormattedDate date={post.data.pubDate} /></span>
              </div>
            </a>
          ))}
        </div>
      </section>

    </main>
    <Footer />
  </body>
</html>

<style>
  /* HERO */
  .hero {
    background: linear-gradient(135deg, #2d7a3a 0%, #4caf6e 100%);
    color: white;
    padding: 4em 1em;
    text-align: center;
  }
  .hero-content {
    max-width: 700px;
    margin: 0 auto;
  }
  .hero h1 {
    font-size: 2em;
    line-height: 1.3;
    margin-bottom: 0.5em;
  }
  .hero p {
    font-size: 1.1em;
    opacity: 0.92;
    margin-bottom: 1.5em;
  }
  .btn-primary {
    display: inline-block;
    background: white;
    color: #2d7a3a;
    padding: 0.75em 2em;
    border-radius: 50px;
    font-weight: 700;
    text-decoration: none;
    font-size: 1em;
    transition: transform 0.2s;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
  }

  /* CATEGORIAS */
  .categorias {
    max-width: 960px;
    margin: 3em auto;
    padding: 0 1em;
  }
  .categorias h2 {
    text-align: center;
    margin-bottom: 1.5em;
    color: #1a1a2e;
  }
  .categorias-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 1em;
  }
  .categoria-card {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f0f9f1;
    border: 2px solid #c8e6c9;
    border-radius: 12px;
    padding: 1.25em 0.75em;
    text-decoration: none;
    transition: all 0.2s;
  }
  .categoria-card:hover {
    background: #2d7a3a;
    border-color: #2d7a3a;
  }
  .categoria-card:hover .categoria-nome {
    color: white;
  }
  .categoria-nome {
    font-weight: 600;
    color: #2d7a3a;
    font-size: 0.95em;
    text-align: center;
  }

  /* ARTIGOS RECENTES */
  .artigos-recentes {
    max-width: 960px;
    margin: 3em auto;
    padding: 0 1em;
  }
  .artigos-recentes h2 {
    text-align: center;
    margin-bottom: 1.5em;
    color: #1a1a2e;
  }
  .artigos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5em;
  }
  .artigo-card {
    background: white;
    border-radius: 12px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.08);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s;
  }
  .artigo-card:hover {
    transform: translateY(-4px);
  }
  .artigo-card img {
    width: 100%;
    height: 180px;
    object-fit: cover;
  }
  .artigo-info {
    padding: 1em;
  }
  .artigo-info h3 {
    font-size: 1em;
    margin: 0 0 0.5em;
    color: #1a1a2e;
    line-height: 1.4;
  }
  .artigo-info p {
    font-size: 0.85em;
    color: #666;
    margin: 0 0 0.75em;
    line-height: 1.5;
  }
  .artigo-data {
    font-size: 0.75em;
    color: #999;
  }

  @media (max-width: 720px) {
    .hero h1 {
      font-size: 1.5em;
    }
    .artigos-grid {
      grid-template-columns: 1fr;
    }
  }
</style>