---
import { SITE_TITLE, SITE_EMAIL, CATEGORIES } from '../consts';
const today = new Date();
---

<footer>
  <div class="footer-content">
    <div class="footer-brand">
      <span class="footer-logo">🐾 {SITE_TITLE}</span>
      <p>Dicas práticas de saúde, alimentação e cuidados para cães e gatos. Para famílias que amam seus pets.</p>
    </div>
    <div class="footer-links">
      <h3>Categorias</h3>
      <ul>
        {CATEGORIES.map((cat) => (
          <li><a href={`/categoria/${cat.slug}/`}>{cat.name}</a></li>
        ))}
      </ul>
    </div>
    <div class="footer-links">
      <h3>Blog</h3>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/blog">Artigos</a></li>
        <li><a href="/about">Sobre</a></li>
        <li><a href="/about">Sobre</a></li>
        <li><a href="/privacidade">Política de Privacidade</a></li>
        <li><a href={`mailto:${SITE_EMAIL}`}>Contato</a></li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <p>&copy; {today.getFullYear()} {SITE_TITLE}. Todos os direitos reservados.</p>
    <p class="disclaimer">Este site contém links de afiliados. Ao comprar através deles, você nos ajuda a manter o conteúdo gratuito, sem custo adicional para você.</p>
  </div>
</footer>

<style>
  footer {
    background: #1a1a2e;
    color: #ccc;
    padding: 3em 1em 1.5em;
    margin-top: 4em;
  }
  .footer-content {
    display: flex;
    flex-wrap: wrap;
    gap: 2em;
    max-width: 960px;
    margin: 0 auto 2em;
    justify-content: space-between;
  }
  .footer-brand {
    flex: 1;
    min-width: 200px;
    max-width: 320px;
  }
  .footer-logo {
    font-size: 1.2em;
    font-weight: 700;
    color: #4caf6e;
  }
  .footer-brand p {
    font-size: 0.85em;
    line-height: 1.6;
    margin-top: 0.75em;
    color: #aaa;
  }
  .footer-links h3 {
    color: #4caf6e;
    font-size: 0.9em;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.75em;
  }
  .footer-links ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .footer-links ul li {
    margin-bottom: 0.4em;
  }
  .footer-links ul li a {
    color: #aaa;
    text-decoration: none;
    font-size: 0.9em;
  }
  .footer-links ul li a:hover {
    color: #4caf6e;
  }
  .footer-bottom {
    border-top: 1px solid #333;
    padding-top: 1.5em;
    text-align: center;
    max-width: 960px;
    margin: 0 auto;
  }
  .footer-bottom p {
    font-size: 0.8em;
    color: #888;
    margin: 0.25em 0;
  }
  .disclaimer {
    font-size: 0.75em !important;
    color: #666 !important;
    margin-top: 0.5em !important;
  }
  @media (max-width: 720px) {
    .footer-content {
      flex-direction: column;
      gap: 1.5em;
    }
    .footer-brand {
      max-width: 100%;
    }
  }
</style>